#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
usage: scripts/check [--fast|--ci|--full]

Runs sessh verification. With no mode, defaults to --fast.

Options:
  --fast    Build sessh-dev and run a fake-ssh smoke connect.
  --ci      Run the CI suite: Zig build/tests, bootstrapper harness,
            fake-ssh harness, and socket harness.
  --full    Run --ci plus the slow Podman ssh harness.
EOF
}

run() {
  printf '\n==> %s\n' "$*"
  "$@"
}

setup_isolation() {
  isolation_parent=${TMPDIR:-/tmp}
  SESSH_CHECK_ISOLATION_ROOT=$(mktemp -d "$isolation_parent/sessh-check.XXXXXX")
  SESSH_CHECK_HOME=$SESSH_CHECK_ISOLATION_ROOT/home
  SESSH_CHECK_XDG_RUNTIME_DIR=$SESSH_CHECK_ISOLATION_ROOT/runtime
  SESSH_CHECK_XDG_CACHE_HOME=$SESSH_CHECK_ISOLATION_ROOT/cache
  SESSH_CHECK_XDG_CONFIG_HOME=$SESSH_CHECK_ISOLATION_ROOT/config
  SESSH_CHECK_XDG_DATA_HOME=$SESSH_CHECK_ISOLATION_ROOT/data
  SESSH_CHECK_XDG_STATE_HOME=$SESSH_CHECK_ISOLATION_ROOT/state
  SESSH_CHECK_TMPDIR=$SESSH_CHECK_ISOLATION_ROOT/tmp
  mkdir -p "$SESSH_CHECK_HOME" "$SESSH_CHECK_XDG_RUNTIME_DIR" "$SESSH_CHECK_XDG_CACHE_HOME" "$SESSH_CHECK_XDG_CONFIG_HOME" "$SESSH_CHECK_XDG_DATA_HOME" "$SESSH_CHECK_XDG_STATE_HOME" "$SESSH_CHECK_TMPDIR"
  chmod 700 "$SESSH_CHECK_HOME" "$SESSH_CHECK_XDG_RUNTIME_DIR" "$SESSH_CHECK_XDG_CACHE_HOME" "$SESSH_CHECK_XDG_CONFIG_HOME" "$SESSH_CHECK_XDG_DATA_HOME" "$SESSH_CHECK_XDG_STATE_HOME" "$SESSH_CHECK_TMPDIR"
}

check_isolation_empty() {
  context=${1-}
  leaked=0
  for dir in "$SESSH_CHECK_HOME" "$SESSH_CHECK_XDG_RUNTIME_DIR" "$SESSH_CHECK_XDG_CACHE_HOME" "$SESSH_CHECK_XDG_CONFIG_HOME" "$SESSH_CHECK_XDG_DATA_HOME" "$SESSH_CHECK_XDG_STATE_HOME" "$SESSH_CHECK_TMPDIR"; do
    first=$(find "$dir" -mindepth 1 -print -quit)
    if [ -n "$first" ]; then
      leaked=1
      if [ -n "$context" ]; then
        printf 'scripts/check: isolation directory is not empty after %s: %s\n' "$context" "$dir" >&2
      else
        printf 'scripts/check: isolation directory is not empty: %s\n' "$dir" >&2
      fi
      find "$dir" -mindepth 1 -maxdepth 4 -print >&2
    fi
  done
  return "$leaked"
}

cleanup_isolation() {
  status=$?
  if [ -n "${SESSH_CHECK_ISOLATION_ROOT:-}" ]; then
    if [ "$status" -eq 0 ]; then
      if ! check_isolation_empty; then
        status=1
      else
        rm -rf "$SESSH_CHECK_ISOLATION_ROOT"
      fi
    else
      printf 'scripts/check: leaving isolation root for inspection: %s\n' "$SESSH_CHECK_ISOLATION_ROOT" >&2
    fi
  fi
  exit "$status"
}

run_isolated() {
  printf '\n==> %s\n' "$*"
  HOME=$SESSH_CHECK_HOME \
    HISTFILE=/dev/null \
    SESSH_TEST_BIN=zig-out/bin/sessh-dev \
    XDG_RUNTIME_DIR=$SESSH_CHECK_XDG_RUNTIME_DIR \
    XDG_CACHE_HOME=$SESSH_CHECK_XDG_CACHE_HOME \
    XDG_CONFIG_HOME=$SESSH_CHECK_XDG_CONFIG_HOME \
    XDG_DATA_HOME=$SESSH_CHECK_XDG_DATA_HOME \
    XDG_STATE_HOME=$SESSH_CHECK_XDG_STATE_HOME \
    TMPDIR=$SESSH_CHECK_TMPDIR \
    "$@"
  check_isolation_empty "$*"
}

run_with_host_podman_environment() {
  printf '\n==> %s\n' "$*"
  (
    # Podman itself is outside sessh's test isolation. It reads the caller's
    # normal HOME/XDG config to find the configured Podman machine and may use
    # the caller's runtime/temp settings to reach its socket. The Podman harness
    # creates isolated sessh client environments internally, so only point it at
    # the freshly built binary here.
    HISTFILE=/dev/null
    SESSH_TEST_BIN=zig-out/bin/sessh-dev
    export HISTFILE SESSH_TEST_BIN
    "$@"
  )
  check_isolation_empty "$*"
}

find_zig() {
  if [ -n "${ZIG:-}" ]; then
    printf '%s\n' "$ZIG"
  elif [ -x /opt/homebrew/opt/zig@0.15/bin/zig ]; then
    printf '%s\n' /opt/homebrew/opt/zig@0.15/bin/zig
  elif [ -x /usr/local/opt/zig@0.15/bin/zig ]; then
    printf '%s\n' /usr/local/opt/zig@0.15/bin/zig
  elif command -v zig >/dev/null 2>&1; then
    command -v zig
  else
    echo "missing Zig 0.15.2" >&2
    exit 1
  fi
}

find_protoc() {
  if [ -n "${SESSH_PROTOC:-}" ]; then
    printf '%s\n' "$SESSH_PROTOC"
  elif command -v protoc-33.0.0 >/dev/null 2>&1; then
    command -v protoc-33.0.0
  elif [ -x /opt/homebrew/opt/protobuf/bin/protoc ]; then
    printf '%s\n' /opt/homebrew/opt/protobuf/bin/protoc
  elif [ -x /usr/local/opt/protobuf/bin/protoc ]; then
    printf '%s\n' /usr/local/opt/protobuf/bin/protoc
  elif command -v protoc >/dev/null 2>&1 && protoc --version >/dev/null 2>&1; then
    command -v protoc
  else
    cat >&2 <<'EOF'
missing protobuf protoc.

Install it with:
  brew install protobuf

If your PATH has a wrapper protoc, set SESSH_PROTOC to the real protobuf binary,
for example:
  SESSH_PROTOC=/opt/homebrew/opt/protobuf/bin/protoc scripts/check
EOF
    exit 1
  fi
}

check_python_protobuf() {
  if ! python3 - <<'PY' >/dev/null 2>&1
import google.protobuf
PY
  then
    cat >&2 <<'EOF'
missing Python protobuf package.

Install it into the Python environment used by scripts/check, for example:
  python3 -m pip install protobuf

If you use a virtualenv, activate it before running scripts/check.
EOF
    exit 1
  fi
}

mode=fast

case "${1-}" in
  "")
    ;;
  --fast)
    mode=fast
    shift
    ;;
  --ci)
    mode=ci
    shift
    ;;
  --full)
    mode=full
    shift
    ;;
  --help|-h)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 64
    ;;
esac

if [ "$#" -ne 0 ]; then
  usage >&2
  exit 64
fi

zig_bin=$(find_zig)
zig_version=$("$zig_bin" version)
if [ "$zig_version" != "0.15.2" ]; then
  echo "expected Zig 0.15.2, got $zig_version from $zig_bin" >&2
  exit 1
fi
protoc_bin=$(find_protoc)
export SESSH_PROTOC=$protoc_bin

case "$mode" in
  fast)
    run "$zig_bin" build install-dev
    setup_isolation
    trap cleanup_isolation EXIT
    run_isolated python3 tests/ssh_harness.py --case "ssh transport uploads artifact and reaches broker"
    run git diff --check
    ;;
  ci|full)
    check_python_protobuf

    run "$zig_bin" build gen-proto
    run sh -n scripts/build scripts/check scripts/download-ghostty-deps scripts/install
    run python3 -m py_compile scripts/release
    run "$zig_bin" fmt --check build.zig build.zig.zon src/*.zig
    run "$zig_bin" build
    run "$zig_bin" build install-dev
    run "$zig_bin" build test
    setup_isolation
    trap cleanup_isolation EXIT
    run_isolated python3 tests/bootstrapper_harness.py
    run_isolated python3 tests/ssh_harness.py
    run_isolated python3 tests/ssh_reconnect_tmux_harness.py
    run_isolated python3 tests/socket_harness.py
    if [ "$mode" = "full" ]; then
      printf '\n==> Slow Podman ssh harness is about to start. Run `scripts/check --ci` to skip it.\n'
      run_with_host_podman_environment python3 tests/podman_ssh_harness.py
    fi
    run git diff --check
    ;;
esac
